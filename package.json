{
  "name": "soma-style",
  "version": "0.2.0",
  "description": "Shared design tokens for the soma ecosystem — macro colors, chart palette, and a Tailwind v4 theme, reused across soma and the standalone macro-engine / hevy2garmin / garmin-auth UIs.",
  "license": "MIT",
  "author": "drkostas",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drkostas/soma-style.git"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./base.css": "./css/base.css",
    "./theme.css": "./css/theme.css",
    "./tokens.css": "./css/tokens.css",
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist",
    "css"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
